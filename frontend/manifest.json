{
  "manifest_version": 3,
  "name": "F1 Overlay — Race Explainer",
  "version": "0.3.0",
  "description": "Educational popups for new F1 viewers during live races.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "F1 Overlay"
  }
}
